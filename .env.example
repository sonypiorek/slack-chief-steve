# ── Slack tokens — from api.slack.com/apps → your app ──────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# ── Channel → repo routing ─────────────────────────────────────────────────────
# Single-line JSON mapping each Slack channel ID to an absolute repo path on the VPS.
# Steve only responds in channels listed here; git ops use the mapped repo.
# Get a channel ID: click the channel name → scroll to the bottom → Copy channel ID.
# NOTE: keep this on ONE line, no inline comment after it, no surrounding quotes.
CHANNEL_REPO_MAP={"C0XXXXXXX":"/home/youruser/your-repo","C0YYYYYYY":"/home/youruser/another-repo"}

# Branch Steve pulls from and commits directly to (no feature branches).
REPO_BRANCH=main

# Hours before an in-flight session is auto-killed and its changes pushed.
SESSION_TTL_HOURS=5

# Comma-separated Slack user IDs allowed to use Steve (empty = allow everyone).
# Get your ID: Slack profile → ⋯ → Copy member ID.
ALLOWED_SLACK_USER_IDS=UXXXXXXXX,UYYYYYYYY

# Optional: absolute path to the claude binary (defaults to /home/youruser/.local/bin/claude).
# CLAUDE_BIN=/home/youruser/.local/bin/claude

# Image attachments: attaching an image to a `@Steve` message lets Claude read it.
# Requires the `files:read` scope on the Slack app (reinstall the app after adding it).
# Images download to a per-run OS temp dir and are deleted when the run ends —
# nothing is persisted, so there's no path to configure.

# ── Removed / obsolete (no longer read) ─────────────────────────────────────────
# REPO_PATH                     → replaced by CHANNEL_REPO_MAP
# SLACK_CHANNEL_ID              → replaced by CHANNEL_REPO_MAP
# CLAUDE_WORKING_BRANCH_PREFIX  → Steve commits directly to REPO_BRANCH now
